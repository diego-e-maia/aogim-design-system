---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';
import Button from '../../../components/ui/Button.astro';
---

<MainLayout locale="es" title="Recursos | AOGIM Design System" description="Herramientas y materiales para el equipo — plantillas Holyrics, overlays OBS, biblioteca de assets y descargas.">
  <Section title="Recursos" description="Herramientas y materiales para el equipo.">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/holyrics">
          <span class="text-3xl mb-4 block">🎵</span>
          <h3 class="text-xl font-semibold mb-2">Holyrics</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Plantillas y configuraciones para el software de presentación Holyrics.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/obs">
          <span class="text-3xl mb-4 block">🎥</span>
          <h3 class="text-xl font-semibold mb-2">OBS Studio</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Overlays, escenas y configuraciones para transmisión en vivo.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/biblioteca">
          <span class="text-3xl mb-4 block">📚</span>
          <h3 class="text-xl font-semibold mb-2">Biblioteca</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Assets, medios y recursos visuales para descargar.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/downloads">
          <span class="text-3xl mb-4 block">📦</span>
          <h3 class="text-xl font-semibold mb-2">Descargas</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Archivos del design system para descargar.</p>
        </a>
      </Card>
    </div>
  </Section>
</MainLayout>
