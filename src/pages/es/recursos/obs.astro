---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';
import Callout from '../../../components/ui/Callout.astro';
---

<MainLayout locale="es" title="OBS Studio | AOGIM Design System" description="Overlays, escenas y configuraciones para transmisión en vivo con la identidad visual AOGIM en OBS Studio.">
  <Section title="OBS Studio" description="Overlays, escenas y configuraciones para transmisión en vivo.">
    <div class="space-y-6">
      <p class="text-[rgb(var(--color-text-secondary))]">Configuraciones profesionales para transmisión de los cultos con la identidad visual AOGIM.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Card class="p-6">
          <h3 class="font-semibold mb-2">Overlay Principal</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-3">Overlay con barras laterales y posición para cámara.</p>
          <span class="text-xs text-brand-500 font-medium">1920x1080</span>
        </Card>
        <Card class="p-6">
          <h3 class="font-semibold mb-2">Overlay de Música</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-3">Overlay optimizado para visualización de letras.</p>
          <span class="text-xs text-brand-500 font-medium">1920x1080</span>
        </Card>
        <Card class="p-6">
          <h3 class="font-semibold mb-2">Fondo de Pantalla</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-3">Background animado con gradiente de la marca.</p>
          <span class="text-xs text-brand-500 font-medium">1920x1080</span>
        </Card>
        <Card class="p-6">
          <h3 class="font-semibold mb-2">Escena de Transición</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-3">Pantalla de transición entre momentos del culto.</p>
          <span class="text-xs text-brand-500 font-medium">1920x1080</span>
        </Card>
      </div>

      <Callout>
        Los archivos de escena OBS (.json) estarán disponibles en la sección Descargas.
      </Callout>
    </div>
  </Section>
</MainLayout>
