---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Callout from '../../../components/ui/Callout.astro';
import Card from '../../../components/ui/Card.astro';
import CodeBlock from '../../../components/ui/CodeBlock.astro';
---

<MainLayout locale="es" title="Callouts | AOGIM Design System" description="Alertas y notificaciones visuales con 4 variantes: info, warning, danger y success. Incluye título opcional.">
  <Section title="Callouts" description="Alertas y notificaciones visuales con 4 variantes.">
    <div class="space-y-6 mb-8">
      <Callout title="Información" variant="info">Este es un callout de información para consejos y notas.</Callout>
      <Callout title="Atención" variant="warning">Este es un callout de advertencia sobre algo importante.</Callout>
      <Callout title="Error" variant="danger">Este es un callout de error para problemas críticos.</Callout>
      <Callout title="Éxito" variant="success">Este es un callout de éxito para confirmaciones.</Callout>
    </div>
    <CodeBlock code={`<Callout title="Información" variant="info">
  Este es un callout de información.
</Callout>`} language="astro" filename="Callout.astro" />
    <Card class="p-6 mt-8">
      <h4 class="font-semibold mb-2">Propiedades</h4>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[rgb(var(--color-border))]">
            <th class="text-left p-2">Prop</th>
            <th class="text-left p-2">Tipo</th>
            <th class="text-left p-2">Default</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-[rgb(var(--color-border))]">
            <td class="p-2 font-mono">variant</td>
            <td class="p-2">info | warning | danger | success</td>
            <td class="p-2">info</td>
          </tr>
          <tr>
            <td class="p-2 font-mono">title</td>
            <td class="p-2">string (opcional)</td>
            <td class="p-2">—</td>
          </tr>
        </tbody>
      </table>
    </Card>
  </Section>
</MainLayout>
