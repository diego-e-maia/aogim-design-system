---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Modal from '../../../components/ui/Modal.astro';
import CodeBlock from '../../../components/ui/CodeBlock.astro';
import Card from '../../../components/ui/Card.astro';
---

<MainLayout locale="es" title="Modal | AOGIM Design System" description="Diálogo modal con overlay, animación de entrada, soporte de teclado (Escape) y foco gestionado.">
  <Section title="Modal" description="Diálogo con overlay, animación y soporte de teclado.">
    <div class="space-y-8">
      <div class="flex gap-4">
        <Modal id="modal-example-1" title="Ejemplo de Modal">
          <p slot="trigger">Abrir Modal</p>
          <p class="text-[rgb(var(--color-text-secondary))]">Este es un modal funcional. Haga clic fuera, en el botón Cancelar o presione Escape para cerrar.</p>
        </Modal>
        <Modal id="modal-example-2" title="Sin Footer">
          <p slot="trigger">Sin Footer</p>
          <p class="text-[rgb(var(--color-text-secondary))]">Este modal no muestra el pie con botones. El título también es opcional.</p>
        </Modal>
      </div>

      <CodeBlock code={`<Modal id="mi-modal" title="Título">
  <p slot="trigger">Abrir Modal</p>
  <p>Contenido del modal aquí.</p>
</Modal>`} language="astro" filename="Modal.astro" />

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Propiedades</h4>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <th class="text-left p-2">Prop</th>
              <th class="text-left p-2">Tipo</th>
              <th class="text-left p-2">Default</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <td class="p-2 font-mono">id</td>
              <td class="p-2">string</td>
              <td class="p-2">—</td>
            </tr>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <td class="p-2 font-mono">title</td>
              <td class="p-2">string (opcional)</td>
              <td class="p-2">—</td>
            </tr>
            <tr>
              <td class="p-2 font-mono">trigger</td>
              <td class="p-2">slot</td>
              <td class="p-2">—</td>
            </tr>
          </tbody>
        </table>
      </Card>

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Comportamiento</h4>
        <ul class="space-y-2 text-sm text-[rgb(var(--color-text-secondary))]">
          <li>• Se cierra al hacer clic en el overlay (backdrop)</li>
          <li>• Se cierra al presionar Escape</li>
          <li>• Animación de entrada con scale + fade</li>
          <li>• Bloquea el scroll del body mientras está abierto</li>
        </ul>
      </Card>
    </div>
  </Section>
</MainLayout>
