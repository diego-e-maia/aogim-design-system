---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';
import Button from '../../../components/ui/Button.astro';

---

<MainLayout locale="es" title="Componentes | AOGIM Design System" description="Elementos reutilizables para construir interfaces consistentes — botones, cards, callouts, badges, formularios, modales, accordion, tabs y tooltip.">
  <Section title="Componentes" description="Elementos reutilizables para construir interfaces consistentes.">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/botoes">
          <h3 class="font-semibold mb-2">Botones</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-4">Primary, secondary, ghost y danger en 3 tamaños.</p>
          <div class="flex gap-2">
            <Button size="sm">Primary</Button>
            <Button variant="secondary" size="sm">Secondary</Button>
          </div>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/cards">
          <h3 class="font-semibold mb-2">Cards</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Contenedores versátiles para agrupar contenido con estilo consistente.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/callouts">
          <h3 class="font-semibold mb-2">Callouts</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Alertas y notificaciones con variantes info, warning, danger y success.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/badges">
          <h3 class="font-semibold mb-2">Badges</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Tags e indicadores de estado en múltiples colores.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/formularios">
          <h3 class="font-semibold mb-2">Formularios</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Inputs, selects y elementos de formulario estandarizados.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/modais">
          <h3 class="font-semibold mb-2">Modales</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Diálogos y ventanas modales para interacciones enfocadas.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/accordion">
          <h3 class="font-semibold mb-2">Acordeón</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Secciones plegables con animación suave.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/tabs">
          <h3 class="font-semibold mb-2">Pestañas</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Navegación por pestañas con soporte de teclado.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/tooltip">
          <h3 class="font-semibold mb-2">Tooltip</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Consejos contextuales al pasar el mouse.</p>
        </a>
      </Card>
    </div>
  </Section>
</MainLayout>
