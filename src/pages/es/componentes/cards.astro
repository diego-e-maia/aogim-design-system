---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';
import CodeBlock from '../../../components/ui/CodeBlock.astro';
---

<MainLayout locale="es" title="Cards | AOGIM Design System" description="Contenedores versátiles para agrupar contenido con estilo consistente. Soporta padding, hover y composición.">
  <Section title="Cards" description="Contenedores versátiles para agrupar contenido.">
    <div class="space-y-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <Card class="p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-500/10 mb-3"></div>
          <h3 class="font-semibold mb-1">Título</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Contenido del card con descripción.</p>
        </Card>
        <Card class="p-6">
          <div class="w-10 h-10 rounded-lg bg-sacred-500/10 mb-3"></div>
          <h3 class="font-semibold mb-1">Título</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Contenido del card con descripción.</p>
        </Card>
        <Card class="p-6">
          <div class="w-10 h-10 rounded-lg bg-green-500/10 mb-3"></div>
          <h3 class="font-semibold mb-1">Título</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Contenido del card con descripción.</p>
        </Card>
      </div>
      <CodeBlock code={`<Card class="p-6">
  <div class="w-10 h-10 rounded-lg bg-brand-500/10 mb-3"></div>
  <h3 class="font-semibold mb-1">Título</h3>
  <p class="text-sm text-[rgb(var(--color-text-secondary))]">
    Contenido del card con descripción.
  </p>
</Card>`} language="astro" filename="Card.astro" />
    </div>
  </Section>
</MainLayout>
