---
import { getCollection } from 'astro:content';
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';

const brandEntries = await getCollection('brand-es');
brandEntries.sort((a, b) => a.data.order - b.data.order);

const icons: Record<string, string> = {
  mark: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  palette: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  type: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  image: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  grid: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z',
  icons: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664zM21 12a9 9 0 11-18 0 9 9 0 0118 0z',
};
const colors = ['brand-500', 'sacred-500', 'green-500', 'yellow-500', 'red-500', 'indigo-500'];
---

<MainLayout locale="es" title="Fundamentos | AOGIM Design System" description="Los pilares visuales y conceptuales del sistema de diseño de AOGIM — marca, colores, tipografía, fotografía, espaciados e iconos.">
  <Section title="Fundamentos" description="Los pilares visuales y conceptuales del sistema de diseño de AOGIM.">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {brandEntries.map((entry, i) => (
        <Card class="p-8 hover:border-brand-500/50 transition-colors">
          <a href={`/es/fundamentos/${entry.slug}`}>
            <div class={`w-12 h-12 rounded-xl bg-${colors[i]}/10 flex items-center justify-center mb-4`}>
              <svg class={`w-6 h-6 text-${colors[i]}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[entry.data.icon || 'mark']} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">{entry.data.title}</h3>
            <p class="text-[rgb(var(--color-text-secondary))]">{entry.data.description}</p>
          </a>
        </Card>
      ))}
    </div>
  </Section>
</MainLayout>
