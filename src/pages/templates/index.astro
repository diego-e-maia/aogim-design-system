---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
---

<MainLayout title="Templates | AOGIM Design System" description="Modelos prontos para páginas, posts e eventos da AOGIM.">
  <Section title="Templates" description="Modelos prontos para páginas, posts e eventos.">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/templates/paginas">
          <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Páginas</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Layouts de página para landing pages, institucionais e internas.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/templates/posts">
          <div class="w-12 h-12 rounded-xl bg-sacred-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-sacred-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Posts</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Templates para artigos, notícias e posts de blog.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/templates/eventos">
          <div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Eventos</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Modelos para divulgação e detalhamento de eventos.</p>
        </a>
      </Card>
    </div>
  </Section>
</MainLayout>
