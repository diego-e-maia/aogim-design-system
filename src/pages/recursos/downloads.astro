---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Callout from '../../components/ui/Callout.astro';
---

<MainLayout title="Downloads | AOGIM Design System" description="Arquivos do design system prontos para download — logo, paletas, tokens, templates Holyrics e overlays OBS.">
  <Section title="Downloads" description="Arquivos do design system prontos para download.">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Logo AOGIM</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">SVG — gradiente, fundo claro e escuro</p>
        </div>
        <div class="flex gap-2">
          <a href="/assets/logo/aogim-logo.svg" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors">Download</a>
        </div>
      </Card>

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Paleta de Cores</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">JSON + CSS — cores da marca</p>
        </div>
        <div class="flex gap-2">
          <a href="/assets/colors/aogim-colors.json" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors">JSON</a>
          <a href="/assets/colors/aogim-colors.css" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-dark-100 dark:bg-dark-800 text-[rgb(var(--color-text))] hover:bg-dark-200 dark:hover:bg-dark-700 transition-colors">CSS</a>
        </div>
      </Card>

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Design Tokens</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">JSON + CSS — cores, tipografia, espaçamentos</p>
        </div>
        <div class="flex gap-2">
          <a href="/assets/tokens/aogim-tokens.json" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors">JSON</a>
          <a href="/assets/tokens/aogim-tokens.css" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-dark-100 dark:bg-dark-800 text-[rgb(var(--color-text))] hover:bg-dark-200 dark:hover:bg-dark-700 transition-colors">CSS</a>
        </div>
      </Card>

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Fontes</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Google Fonts — Inter + JetBrains Mono</p>
        </div>
        <a href="https://fonts.google.com/specimen/Inter" target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-dark-100 dark:bg-dark-800 text-[rgb(var(--color-text))] hover:bg-dark-200 dark:hover:bg-dark-700 transition-colors">Link</a>
      </Card>

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Template Holyrics — Letra</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">HTML — tela de letras para projeção</p>
        </div>
        <a href="/assets/holyrics/template-letra.html" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors">Download</a>
      </Card>

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Template Holyrics — Avisos</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">HTML — tela de avisos para projeção</p>
        </div>
        <a href="/assets/holyrics/template-avisos.html" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors">Download</a>
      </Card>

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Overlay OBS — Principal</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">HTML — overlay com barra inferior e logo</p>
        </div>
        <a href="/assets/obs/overlay-principal.html" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors">Download</a>
      </Card>

      <Card class="p-6 flex items-center justify-between">
        <div>
          <h3 class="font-semibold mb-1">Overlay OBS — Música</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">HTML — overlay para letras de música</p>
        </div>
        <a href="/assets/obs/overlay-musica.html" download class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-500 text-white hover:bg-brand-600 transition-colors">Download</a>
      </Card>

    </div>
    <Callout>
      Baixe os arquivos clicando nos botões. Os overlays OBS e templates Holyrics são HTML puro — abra como Browser Source no OBS ou importe no Holyrics.
    </Callout>
  </Section>
</MainLayout>
