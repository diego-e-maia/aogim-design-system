---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
---

<MainLayout title="Recursos | AOGIM Design System" description="Ferramentas e materiais para a equipe — templates Holyrics, overlays OBS, biblioteca de assets e downloads.">
  <Section title="Recursos" description="Ferramentas e materiais para a equipe.">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/holyrics">
          <span class="text-3xl mb-4 block">🎵</span>
          <h3 class="text-xl font-semibold mb-2">Holyrics</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Templates e configurações para o software de apresentação Holyrics.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/obs">
          <span class="text-3xl mb-4 block">🎥</span>
          <h3 class="text-xl font-semibold mb-2">OBS Studio</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Overlays, cenas e configurações para transmissão ao vivo.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/biblioteca">
          <span class="text-3xl mb-4 block">📚</span>
          <h3 class="text-xl font-semibold mb-2">Biblioteca</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Assets, mídias e recursos visuais para download.</p>
        </a>
      </Card>
      <Card class="p-8 hover:border-brand-500/50 transition-colors">
        <a href="/recursos/downloads">
          <span class="text-3xl mb-4 block">📦</span>
          <h3 class="text-xl font-semibold mb-2">Downloads</h3>
          <p class="text-[rgb(var(--color-text-secondary))]">Arquivos do design system para download.</p>
        </a>
      </Card>
    </div>
  </Section>
</MainLayout>
