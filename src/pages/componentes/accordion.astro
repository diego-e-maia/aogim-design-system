---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Accordion from '../../components/ui/Accordion.astro';
import CodeBlock from '../../components/ui/CodeBlock.astro';
import Card from '../../components/ui/Card.astro';

const itemsType = '{ title: string, content: string }[]';
const singleCode = `<Accordion
  items={[
    { title: 'Pergunta 1', content: 'Resposta 1' },
    { title: 'Pergunta 2', content: 'Resposta 2' },
  ]}
/>

<Accordion allowMultiple
  items={[
    { title: 'Item 1', content: 'Conteúdo' },
    { title: 'Item 2', content: 'Conteúdo' },
  ]}
/>`;
---

<MainLayout title="Accordion | AOGIM Design System" description="Seções colapsáveis com animação suave e modos single (uma por vez) e multiple (várias abertas).">
  <Section title="Accordion" description="Seções colapsáveis com animação suave e modos single/multiple.">
    <div class="space-y-8">

      <h3 class="text-2xl font-bold">Single (padrão)</h3>
      <Accordion
        items={[
          { title: 'O que é o AOGIM Design System?', content: 'É um sistema de design completo para a Igreja AOGIM, contendo diretrizes de marca, componentes, templates e recursos para manter a consistência visual em todos os materiais da igreja.' },
          { title: 'Como começar a usar?', content: 'Você pode navegar pela documentação, explorar os componentes disponíveis e fazer download dos assets na seção de Downloads.' },
          { title: 'Tecnologias utilizadas', content: 'O projeto é construído com Astro, TypeScript, Tailwind CSS e MDX. Os componentes são puros com CSS moderno e JavaScript vanilla.' },
        ]}
      />

      <h3 class="text-2xl font-bold mt-8">Multiple (abre vários)</h3>
      <Accordion
        allowMultiple
        items={[
          { title: 'Item 1', content: 'Conteúdo do primeiro item do accordion.' },
          { title: 'Item 2', content: 'Conteúdo do segundo item do accordion.' },
          { title: 'Item 3', content: 'Conteúdo do terceiro item do accordion.' },
        ]}
      />

      <CodeBlock code={singleCode} language="astro" filename="Accordion.astro" />

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Propriedades</h4>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <th class="text-left p-2">Prop</th>
              <th class="text-left p-2">Tipo</th>
              <th class="text-left p-2">Default</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <td class="p-2 font-mono">items</td>
              <td class="p-2">{itemsType}</td>
              <td class="p-2">[]</td>
            </tr>
            <tr>
              <td class="p-2 font-mono">allowMultiple</td>
              <td class="p-2">boolean</td>
              <td class="p-2">false</td>
            </tr>
          </tbody>
        </table>
      </Card>
    </div>
  </Section>
</MainLayout>
