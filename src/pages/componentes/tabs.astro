---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Tabs from '../../components/ui/Tabs.astro';
import CodeBlock from '../../components/ui/CodeBlock.astro';
import Card from '../../components/ui/Card.astro';

const tabsCode = `<Tabs
  tabs={[
    { label: 'HTML', content: 'Conte\u00fado HTML...' },
    { label: 'CSS', content: 'Conte\u00fado CSS...' },
    { label: 'JS', content: 'Conte\u00fado JS...' },
  ]}
/>`;

const typeLabel = '{ label: string, content: string, icon?: string }[]';
---

<MainLayout title="Tabs | AOGIM Design System" description="Navegação por abas com suporte a teclado (setas direcionais), roles ARIA e foco gerenciado.">
  <Section title="Tabs" description="Navegação por abas com suporte a teclado (setas direcionais).">
    <div class="space-y-8">
      <Tabs
        tabs={[
          { label: 'HTML', content: 'Estrutura semântica com role="tablist", role="tab" e role="tabpanel" para acessibilidade.' },
          { label: 'CSS', content: 'Estilização com estados active/inactive, transição suave e tema escuro.' },
          { label: 'JS', content: 'Navegação por clique e setas do teclado (ArrowLeft/ArrowRight) com foco gerenciado.' },
        ]}
      />

      <CodeBlock code={tabsCode} language="astro" filename="Tabs.astro" />

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Propriedades</h4>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <th class="text-left p-2">Prop</th>
              <th class="text-left p-2">Tipo</th>
              <th class="text-left p-2">Default</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-2 font-mono">tabs</td>
              <td class="p-2">{typeLabel}</td>
              <td class="p-2">[]</td>
            </tr>
          </tbody>
        </table>
      </Card>

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Acessibilidade</h4>
        <ul class="space-y-2 text-sm text-[rgb(var(--color-text-secondary))]">
          <li>• Roles ARIA: tablist, tab, tabpanel</li>
          <li>• Navegação por setas esquerda/direita</li>
          <li>• Estado aria-selected sincronizado</li>
          <li>• Foco gerenciado entre abas</li>
        </ul>
      </Card>
    </div>
  </Section>
</MainLayout>
