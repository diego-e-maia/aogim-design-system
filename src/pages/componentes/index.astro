---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import StatusBadge from '../../components/ui/StatusBadge.astro';

const components = [
  { title: 'Botões', href: '/componentes/botoes', desc: 'Primary, secondary, ghost e danger em 3 tamanhos.', status: 'stable' as const },
  { title: 'Cards', href: '/componentes/cards', desc: 'Containers versáteis para agrupar conteúdo.', status: 'stable' as const },
  { title: 'Callouts', href: '/componentes/callouts', desc: 'Alertas e notificações com 4 variantes.', status: 'stable' as const },
  { title: 'Badges', href: '/componentes/badges', desc: 'Tags e indicadores de status em múltiplas cores.', status: 'stable' as const },
  { title: 'Formulários', href: '/componentes/formularios', desc: 'Inputs, selects e elementos padronizados.', status: 'beta' as const },
  { title: 'Modais', href: '/componentes/modais', desc: 'Diálogos e janelas modais para interações focadas.', status: 'stable' as const },
  { title: 'Accordion', href: '/componentes/accordion', desc: 'Seções colapsáveis com animação suave.', status: 'stable' as const },
  { title: 'Tabs', href: '/componentes/tabs', desc: 'Navegação por abas com suporte a teclado.', status: 'stable' as const },
  { title: 'Tooltip', href: '/componentes/tooltip', desc: 'Dicas contextuais ao passar o mouse.', status: 'beta' as const },
];
---

<MainLayout title="Componentes | AOGIM Design System" description="Elementos reutilizáveis para construir interfaces consistentes — botões, cards, callouts, badges, formulários, modais, accordion, tabs e tooltip.">
  <Section title="Componentes" description="Elementos reutilizáveis para construir interfaces consistentes.">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {components.map((comp) => (
        <Card class="p-6 hover:border-brand-500/50 transition-colors">
          <a href={comp.href}>
            <div class="flex items-center gap-2 mb-2">
              <h3 class="font-semibold">{comp.title}</h3>
              <StatusBadge status={comp.status} />
            </div>
            <p class="text-sm text-[rgb(var(--color-text-secondary))]">{comp.desc}</p>
          </a>
        </Card>
      ))}
    </div>
  </Section>
</MainLayout>
