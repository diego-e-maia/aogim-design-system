---
import MainLayout from '../../layouts/MainLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
---

<MainLayout title="Formulários | AOGIM Design System" description="Inputs, selects, textareas e checkboxes padronizados com estados de erro e foco.">
  <Section title="Formulários" description="Inputs, selects e elementos de formulário padronizados.">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-xl font-bold mb-4">Input Text</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1">Label</label>
            <input type="text" placeholder="Placeholder" class="w-full px-4 py-2.5 rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Com erro</label>
            <input type="text" value="valor inválido" class="w-full px-4 py-2.5 rounded-xl border border-red-500 bg-[rgb(var(--color-bg))] text-sm focus:outline-none focus:ring-2 focus:ring-red-500/50 transition-all" />
            <p class="text-xs text-red-500 mt-1">Mensagem de erro</p>
          </div>
        </div>
      </div>
      <div>
        <h3 class="text-xl font-bold mb-4">Textarea</h3>
        <textarea rows="4" placeholder="Escreva aqui..." class="w-full px-4 py-2.5 rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-all resize-none"></textarea>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
      <div>
        <h3 class="text-xl font-bold mb-4">Select</h3>
        <select class="w-full px-4 py-2.5 rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-all">
          <option>Opção 1</option>
          <option>Opção 2</option>
          <option>Opção 3</option>
        </select>
      </div>
      <div>
        <h3 class="text-xl font-bold mb-4">Checkbox</h3>
        <label class="flex items-center gap-3">
          <input type="checkbox" class="w-4 h-4 rounded border-[rgb(var(--color-border))] text-brand-500 focus:ring-brand-500" />
          <span class="text-sm">Opção de exemplo</span>
        </label>
      </div>
    </div>
  </Section>
</MainLayout>
