---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';

const url = Astro.url.pathname;
const locale = url.startsWith('/en/') ? 'en' : url.startsWith('/es/') ? 'es' : 'pt';

const content = {
  pt: {
    title: 'Página não encontrada',
    description: 'A página que você procura não existe ou foi movida.',
    message: 'Verifique o endereço ou volte para o início.',
    home: 'Voltar ao Início',
  },
  en: {
    title: 'Page Not Found',
    description: 'The page you are looking for does not exist or has been moved.',
    message: 'Check the address or go back to the home page.',
    home: 'Back to Home',
  },
  es: {
    title: 'Página no encontrada',
    description: 'La página que buscas no existe o ha sido movida.',
    message: 'Verifica la dirección o vuelve al inicio.',
    home: 'Volver al Inicio',
  },
};

const c = content[locale];
const homeHref = locale === 'pt' ? '/' : `/${locale}/`;
---

<MainLayout locale={locale} title={`404 | AOGIM Design System`} description={c.description}>
  <Section>
    <div class="flex flex-col items-center justify-center text-center py-24">
      <div class="text-8xl font-bold text-brand-500 mb-6">404</div>
      <h1 class="text-3xl font-bold mb-3">{c.title}</h1>
      <p class="text-[rgb(var(--color-text-secondary))] mb-2 max-w-md">{c.description}</p>
      <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-8">{c.message}</p>
      <a
        href={homeHref}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-500 text-white font-medium shadow-lg shadow-brand-500/25 hover:bg-brand-600 transition-all"
      >
        {c.home}
      </a>
    </div>
  </Section>
</MainLayout>
