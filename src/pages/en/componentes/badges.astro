---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Badge from '../../../components/ui/Badge.astro';
import Card from '../../../components/ui/Card.astro';
import CodeBlock from '../../../components/ui/CodeBlock.astro';
---

<MainLayout locale="en" title="Badges | AOGIM Design System" description="Tags and status indicators in multiple colors: default, brand, success, warning, and danger. Sizes sm and md.">
  <Section title="Badges" description="Tags and status indicators in multiple colors.">
    <div class="flex flex-wrap gap-3 mb-8">
      <Badge>Default</Badge>
      <Badge variant="brand">Brand</Badge>
      <Badge variant="success">Success</Badge>
      <Badge variant="warning">Warning</Badge>
      <Badge variant="danger">Danger</Badge>
    </div>
    <div class="flex flex-wrap items-center gap-3 mb-8">
      <Badge size="sm">Small</Badge>
      <Badge size="md">Medium</Badge>
    </div>
    <CodeBlock code={`<Badge>Default</Badge>
<Badge variant="brand">Brand</Badge>
<Badge variant="success">Success</Badge>
<Badge variant="warning">Warning</Badge>
<Badge variant="danger">Danger</Badge>`} language="astro" filename="Badge.astro" />
    <Card class="p-6 mt-8">
      <h4 class="font-semibold mb-2">Properties</h4>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[rgb(var(--color-border))]">
            <th class="text-left p-2">Prop</th>
            <th class="text-left p-2">Type</th>
            <th class="text-left p-2">Default</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-[rgb(var(--color-border))]">
            <td class="p-2 font-mono">variant</td>
            <td class="p-2">default | brand | success | warning | danger</td>
            <td class="p-2">default</td>
          </tr>
          <tr>
            <td class="p-2 font-mono">size</td>
            <td class="p-2">sm | md</td>
            <td class="p-2">md</td>
          </tr>
        </tbody>
      </table>
    </Card>
  </Section>
</MainLayout>
