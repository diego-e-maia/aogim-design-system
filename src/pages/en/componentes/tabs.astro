---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Tabs from '../../../components/ui/Tabs.astro';
import CodeBlock from '../../../components/ui/CodeBlock.astro';
import Card from '../../../components/ui/Card.astro';

const tabsCode = `<Tabs
  tabs={[
    { label: 'HTML', content: 'HTML content...' },
    { label: 'CSS', content: 'CSS content...' },
    { label: 'JS', content: 'JS content...' },
  ]}
/>`;

const typeLabel = '{ label: string, content: string, icon?: string }[]';
---

<MainLayout locale="en" title="Tabs | AOGIM Design System" description="Tab navigation with keyboard support (arrow keys), ARIA roles, and managed focus.">
  <Section title="Tabs" description="Tab navigation with keyboard support (arrow keys).">
    <div class="space-y-8">
      <Tabs
        tabs={[
          { label: 'HTML', content: 'Semantic structure with role="tablist", role="tab", and role="tabpanel" for accessibility.' },
          { label: 'CSS', content: 'Styling with active/inactive states, smooth transitions, and dark theme.' },
          { label: 'JS', content: 'Navigation by click and arrow keys (ArrowLeft/ArrowRight) with managed focus.' },
        ]}
      />

      <CodeBlock code={tabsCode} language="astro" filename="Tabs.astro" />

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Properties</h4>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <th class="text-left p-2">Prop</th>
              <th class="text-left p-2">Type</th>
              <th class="text-left p-2">Default</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-2 font-mono">tabs</td>
              <td class="p-2">{typeLabel}</td>
              <td class="p-2">[]</td>
            </tr>
          </tbody>
        </table>
      </Card>

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Accessibility</h4>
        <ul class="space-y-2 text-sm text-[rgb(var(--color-text-secondary))]">
          <li>• ARIA roles: tablist, tab, tabpanel</li>
          <li>• Left/right arrow navigation</li>
          <li>• Synced aria-selected state</li>
          <li>• Managed focus between tabs</li>
        </ul>
      </Card>
    </div>
  </Section>
</MainLayout>
