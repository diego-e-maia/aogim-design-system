---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';
import Button from '../../../components/ui/Button.astro';

---

<MainLayout locale="en" title="Components | AOGIM Design System" description="Reusable elements to build consistent interfaces — buttons, cards, callouts, badges, forms, modals, accordion, tabs, and tooltip.">
  <Section title="Components" description="Reusable elements to build consistent interfaces.">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/botoes">
          <h3 class="font-semibold mb-2">Buttons</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-4">Primary, secondary, ghost and danger in 3 sizes.</p>
          <div class="flex gap-2">
            <Button size="sm">Primary</Button>
            <Button variant="secondary" size="sm">Secondary</Button>
          </div>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/cards">
          <h3 class="font-semibold mb-2">Cards</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Versatile containers for grouping content with consistent style.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/callouts">
          <h3 class="font-semibold mb-2">Callouts</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Alerts and notifications with info, warning, danger, and success variants.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/badges">
          <h3 class="font-semibold mb-2">Badges</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Tags and status indicators in multiple colors.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/formularios">
          <h3 class="font-semibold mb-2">Forms</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Inputs, selects, and standardized form elements.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/modais">
          <h3 class="font-semibold mb-2">Modals</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Dialogs and modals for focused interactions.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/accordion">
          <h3 class="font-semibold mb-2">Accordion</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Collapsible sections with smooth animation.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/tabs">
          <h3 class="font-semibold mb-2">Tabs</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Tab navigation with keyboard support.</p>
        </a>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <a href="/componentes/tooltip">
          <h3 class="font-semibold mb-2">Tooltip</h3>
          <p class="text-sm text-[rgb(var(--color-text-secondary))]">Contextual tooltips on hover.</p>
        </a>
      </Card>
    </div>
  </Section>
</MainLayout>
