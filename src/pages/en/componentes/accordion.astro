---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Accordion from '../../../components/ui/Accordion.astro';
import CodeBlock from '../../../components/ui/CodeBlock.astro';
import Card from '../../../components/ui/Card.astro';

const itemsType = '{ title: string, content: string }[]';
const singleCode = `<Accordion
  items={[
    { title: 'Question 1', content: 'Answer 1' },
    { title: 'Question 2', content: 'Answer 2' },
  ]}
/>

<Accordion allowMultiple
  items={[
    { title: 'Item 1', content: 'Content' },
    { title: 'Item 2', content: 'Content' },
  ]}
/>`;
---

<MainLayout locale="en" title="Accordion | AOGIM Design System" description="Collapsible sections with smooth animation and single (one at a time) and multiple modes.">
  <Section title="Accordion" description="Collapsible sections with smooth animation and single/multiple modes.">
    <div class="space-y-8">

      <h3 class="text-2xl font-bold">Single (default)</h3>
      <Accordion
        items={[
          { title: 'What is the AOGIM Design System?', content: 'It is a complete design system for AOGIM Church, containing brand guidelines, components, templates and resources to maintain visual consistency across all church materials.' },
          { title: 'How to get started?', content: 'You can browse the documentation, explore the available components, and download assets from the Downloads section.' },
          { title: 'Technologies used', content: 'The project is built with Astro, TypeScript, Tailwind CSS, and MDX. The components are pure with modern CSS and vanilla JavaScript.' },
        ]}
      />

      <h3 class="text-2xl font-bold mt-8">Multiple (opens several)</h3>
      <Accordion
        allowMultiple
        items={[
          { title: 'Item 1', content: 'Content of the first accordion item.' },
          { title: 'Item 2', content: 'Content of the second accordion item.' },
          { title: 'Item 3', content: 'Content of the third accordion item.' },
        ]}
      />

      <CodeBlock code={singleCode} language="astro" filename="Accordion.astro" />

      <Card class="p-6">
        <h4 class="font-semibold mb-3">Properties</h4>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <th class="text-left p-2">Prop</th>
              <th class="text-left p-2">Type</th>
              <th class="text-left p-2">Default</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[rgb(var(--color-border))]">
              <td class="p-2 font-mono">items</td>
              <td class="p-2">{itemsType}</td>
              <td class="p-2">[]</td>
            </tr>
            <tr>
              <td class="p-2 font-mono">allowMultiple</td>
              <td class="p-2">boolean</td>
              <td class="p-2">false</td>
            </tr>
          </tbody>
        </table>
      </Card>
    </div>
  </Section>
</MainLayout>
