---
import MainLayout from '../../../layouts/MainLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Card from '../../../components/ui/Card.astro';
---

<MainLayout locale="en" title="Posts | AOGIM Design System" description="Templates for articles, news, and blog posts with author and date metadata.">
  <Section title="Posts" description="Templates for articles, news, and blog posts.">
    <div class="space-y-6">
      <Card class="p-6">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-full bg-brand-500/20"></div>
          <div>
            <p class="text-sm font-medium">Author</p>
            <p class="text-xs text-[rgb(var(--color-text-secondary))]">12 Jan 2024</p>
          </div>
        </div>
        <h3 class="text-xl font-semibold mb-2">Post Title</h3>
        <p class="text-[rgb(var(--color-text-secondary))] mb-3">Post content summary with brief description...</p>
        <span class="text-sm text-brand-500 font-medium">Read more →</span>
      </Card>
      <Card class="p-6">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-full bg-sacred-500/20"></div>
          <div>
            <p class="text-sm font-medium">Author</p>
            <p class="text-xs text-[rgb(var(--color-text-secondary))]">10 Jan 2024</p>
          </div>
        </div>
        <h3 class="text-xl font-semibold mb-2">Another Post</h3>
        <p class="text-[rgb(var(--color-text-secondary))] mb-3">Post content summary with brief description...</p>
        <span class="text-sm text-brand-500 font-medium">Read more →</span>
      </Card>
    </div>
  </Section>
</MainLayout>
