---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/ui/Hero.astro';
import Card from '../../components/ui/Card.astro';
import Section from '../../components/ui/Section.astro';
import { getTranslations } from '../../i18n';

const t = getTranslations('en');
---

<MainLayout
  locale="en"
  title="AOGIM Design System"
  description="Official Design System of AOGIM Church — brand guidelines, components, templates, and resources to maintain visual consistency across all church materials."
  image="/og-image.svg"
>
  <Hero
    title={t.hero.title}
    description={t.hero.description}
  >
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="/en/fundamentos"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-500 text-white font-medium shadow-lg shadow-brand-500/25 hover:bg-brand-600 transition-all"
      >
        {t.hero.start}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="/en/componentes"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-dark-100 dark:bg-dark-800 text-[rgb(var(--color-text))] font-medium border border-[rgb(var(--color-border))] hover:bg-dark-200 dark:hover:bg-dark-700 transition-all"
      >
        {t.hero.components}
      </a>
    </div>
  </Hero>

  <Section
    title={t.sections.fundamentals}
    description={t.sections.fundamentalsDesc}
  >
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-brand-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/fundamentos/brand" class="hover:text-brand-500 transition-colors">Brand</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">
          Visual identity, logo, and usage guidelines.
        </p>
      </Card>

      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-sacred-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-sacred-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/fundamentos/colors" class="hover:text-brand-500 transition-colors">Colors</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">
          Color palette and usage semantics.
        </p>
      </Card>

      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-green-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/fundamentos/typography" class="hover:text-brand-500 transition-colors">Typography</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">
          Type scale and text hierarchy.
        </p>
      </Card>

      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-yellow-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/fundamentos/photography" class="hover:text-brand-500 transition-colors">Photography</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">
          Image and photography guidelines.
        </p>
      </Card>

      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/fundamentos/spacing" class="hover:text-brand-500 transition-colors">Spacing</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">
          Grid and spacing system.
        </p>
      </Card>

      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/fundamentos/icons" class="hover:text-brand-500 transition-colors">Icons</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">
          Icon library and usage guidelines.
        </p>
      </Card>
    </div>
  </Section>

  <Section
    title={t.sections.components}
    description={t.sections.componentsDesc}
  >
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <h3 class="font-semibold mb-2">
          <a href="/componentes/botoes" class="hover:text-brand-500 transition-colors">Buttons</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Various button styles and variants.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <h3 class="font-semibold mb-2">
          <a href="/en/componentes/cards" class="hover:text-brand-500 transition-colors">Cards</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Containers for grouping content.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <h3 class="font-semibold mb-2">
          <a href="/en/componentes/callouts" class="hover:text-brand-500 transition-colors">Callouts</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Alerts and visual notifications.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <h3 class="font-semibold mb-2">
          <a href="/en/componentes/badges" class="hover:text-brand-500 transition-colors">Badges</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Tags and status indicators.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <h3 class="font-semibold mb-2">
          <a href="/en/componentes/formularios" class="hover:text-brand-500 transition-colors">Forms</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Inputs, selects, and form elements.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <h3 class="font-semibold mb-2">
          <a href="/en/componentes/modais" class="hover:text-brand-500 transition-colors">Modals</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Dialogs and modal windows.</p>
      </Card>
    </div>
  </Section>

  <Section
    title={t.sections.resources}
    description={t.sections.resourcesDesc}
  >
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
          <span class="text-xl">🎵</span>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/recursos/holyrics" class="hover:text-brand-500 transition-colors">Holyrics</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Templates for presentation.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
          <span class="text-xl">🎥</span>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/recursos/obs" class="hover:text-brand-500 transition-colors">OBS</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Configurations and overlays.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
          <span class="text-xl">📚</span>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/recursos/biblioteca" class="hover:text-brand-500 transition-colors">Library</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Assets and visual resources.</p>
      </Card>
      <Card class="p-6 hover:border-brand-500/50 transition-colors">
        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
          <span class="text-xl">📦</span>
        </div>
        <h3 class="font-semibold mb-2">
          <a href="/en/recursos/downloads" class="hover:text-brand-500 transition-colors">Downloads</a>
        </h3>
        <p class="text-sm text-[rgb(var(--color-text-secondary))]">Files for download.</p>
      </Card>
    </div>
  </Section>
</MainLayout>
