---
interface Props {
  locale?: string;
}

const { locale = 'pt' } = Astro.props;

const languages = [
  { code: 'pt', label: 'PT' },
  { code: 'en', label: 'EN' },
  { code: 'es', label: 'ES' },
];
---

<div class="flex items-center gap-1">
  {languages.map((lang) => (
    <a
      href={Astro.url.pathname}
      data-lang={lang.code}
      class:list={[
        'px-2 py-1 rounded text-xs font-medium transition-colors',
        locale === lang.code
          ? 'bg-brand-500/10 text-brand-500'
          : 'text-[rgb(var(--color-text-secondary))] hover:bg-dark-100 dark:hover:bg-dark-800',
      ]}
      aria-label={`Switch to ${lang.label}`}
      onclick="
        event.preventDefault();
        var targetLang = this.dataset.lang;
        localStorage.setItem('locale', targetLang);
        document.querySelectorAll('[data-lang]').forEach(function(el) {
          el.classList.remove('bg-brand-500/10', 'text-brand-500');
        });
        this.classList.add('bg-brand-500/10', 'text-brand-500');
        var path = window.location.pathname;
        var prefix = '';
        if (path.startsWith('/en/') || path.startsWith('/es/')) {
          prefix = path.split('/')[1];
          path = '/' + path.split('/').slice(2).join('/');
        }
        if (targetLang === 'pt') {
          window.location.href = path || '/';
        } else {
          window.location.href = '/' + targetLang + (path || '/');
        }
      "
    >
      {lang.label}
    </a>
  ))}
</div>
