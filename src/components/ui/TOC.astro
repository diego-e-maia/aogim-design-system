---
interface Heading {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
---

{headings.length > 0 && (
  <nav class="sticky top-24 space-y-1" aria-label="Table of contents">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-secondary))] mb-3 px-3">
      Nesta página
    </h3>
    {headings
      .filter((h) => h.depth <= 3)
      .map((h) => (
        <a
          href={`#${h.slug}`}
          class:list={[
            'block text-sm rounded-lg transition-colors',
            h.depth === 3 ? 'pl-6' : 'pl-3',
            'py-1 text-[rgb(var(--color-text-secondary))] hover:text-brand-500 hover:bg-brand-500/5',
          ]}
        >
          {h.text}
        </a>
      ))}
  </nav>
)}
