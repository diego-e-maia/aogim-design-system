---
import type { Translations } from '../i18n/translations';
import { getTranslations } from '../../i18n/index';

interface Props {
  locale?: string;
}

const { locale = 'pt' } = Astro.props;
const t: Translations = getTranslations(locale);
---

<div class="relative">
  <button
    data-toggle-search
    type="button"
    class="w-full flex items-center gap-3 px-4 py-2 rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] text-sm text-[rgb(var(--color-text-secondary))] hover:border-brand-500/50 hover:text-[rgb(var(--color-text))] transition-all text-left cursor-pointer"
  >
    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <span class="flex-1">{t.search}</span>
    <kbd class="hidden sm:inline-flex items-center px-2 py-0.5 rounded text-xs font-mono border border-[rgb(var(--color-border))] text-[rgb(var(--color-text-secondary))]">
      ⌘K
    </kbd>
  </button>
</div>
