---
interface Props {
  code: string;
  language?: string;
  filename?: string;
}

const { code, language = 'text', filename } = Astro.props;
---

<div class="group relative my-6 rounded-xl overflow-hidden border border-[rgb(var(--color-border))] bg-[#0d1117]">
  {filename && (
    <div class="flex items-center justify-between px-4 py-2 bg-dark-900/50 border-b border-[rgb(var(--color-border))]">
      <span class="text-xs text-[rgb(var(--color-text-secondary))] font-mono">{filename}</span>
    </div>
  )}
  <div class="relative">
    <pre class="p-4 overflow-x-auto"><code class={`language-${language}`}>{code}</code></pre>
    <button data-copy class="absolute top-3 right-3 p-2 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity bg-dark-800 hover:bg-dark-700 border border-dark-600" aria-label="Copiar código">
      <svg data-copy-icon class="w-4 h-4 text-[rgb(var(--color-text-secondary))]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      <svg data-check-icon class="w-4 h-4 text-green-400 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const code = btn.closest('.group')?.querySelector('code')?.textContent || '';
      navigator.clipboard.writeText(code).then(() => {
        const icon = btn.querySelector('[data-copy-icon]');
        const check = btn.querySelector('[data-check-icon]');
        icon?.classList.add('hidden');
        check?.classList.remove('hidden');
        setTimeout(() => {
          icon?.classList.remove('hidden');
          check?.classList.add('hidden');
        }, 2000);
      });
    });
  });
</script>
