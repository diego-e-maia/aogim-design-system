---
interface Props {
  code: string;
  language?: string;
  filename?: string;
}

const { code, language = 'typescript', filename } = Astro.props;
---

<div class="rounded-xl border border-[rgb(var(--color-border))] overflow-hidden">
  {filename && (
    <div class="flex items-center justify-between px-4 py-2 bg-dark-100 dark:bg-dark-800 border-b border-[rgb(var(--color-border))]">
      <span class="text-sm font-mono text-[rgb(var(--color-text-secondary))]">{filename}</span>
      <button
        type="button"
        class="copy-btn text-xs text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text))] transition-colors"
        data-code={code}
      >
        Copiar
      </button>
    </div>
  )}
  <pre class="p-4 overflow-x-auto bg-dark-950 dark:bg-dark-950"><code class={`language-${language} text-sm font-mono`}>{code}</code></pre>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (code) {
        await navigator.clipboard.writeText(code);
        const originalText = btn.textContent;
        btn.textContent = 'Copiado!';
        setTimeout(() => {
          btn.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>
