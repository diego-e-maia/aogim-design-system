---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  locale?: string;
}

const { title, description, image, canonical, locale = 'pt' } = Astro.props;
const site = 'https://design.aogim.org';
const defaultImage = '/og-image.svg';
const ogImage = image ? `${site}${image}` : `${site}${defaultImage}`;
const url = canonical || Astro.url.href;

const path = Astro.url.pathname;
const locales = ['pt', 'en', 'es'];

function alternateUrl(loc: string): string {
  if (loc === 'pt') return `${site}${path.replace(/^\/(en|es)\//, '/')}`;
  return `${site}/${loc}${path.replace(/^\/(en|es)\/?/, '/')}`;
}
---

<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={url} />

{locales.map((loc) => (
  <link rel="alternate" hreflang={loc} href={alternateUrl(loc)} />
))}
<link rel="alternate" hreflang="x-default" href={`${site}${path.replace(/^\/(en|es)\/?/, '/')}`} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="AOGIM Design System" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={url} />
<meta property="og:locale" content={locale === 'pt' ? 'pt_BR' : locale} />
{locales.filter((l) => l !== locale).map((l) => (
  <meta property="og:locale:alternate" content={l === 'pt' ? 'pt_BR' : l} />
))}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AOGIM Design System',
  url: site,
  description: 'Uma Igreja. Uma Família. Um Lugar de Transformação.',
  inLanguage: [locales.map((l) => l === 'pt' ? 'pt-BR' : l)],
  publisher: {
    '@type': 'Organization',
    name: 'AOGIM',
    url: site,
  },
})} />
