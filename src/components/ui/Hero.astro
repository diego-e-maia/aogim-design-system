---
interface Props {
  title: string;
  description?: string;
  class?: string;
}

const { title, description, class: className = '' } = Astro.props;
---

<div class={`relative py-20 text-center ${className}`}>
  <div class="absolute inset-0 bg-gradient-to-b from-brand-500/5 to-transparent pointer-events-none" />
  <div class="relative">
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6 text-balance" data-reveal="up">
      {title}
    </h1>
    {description && (
      <p class="text-xl text-[rgb(var(--color-text-secondary))] max-w-2xl mx-auto mb-8" data-reveal="up">
        {description}
      </p>
    )}
    <div data-reveal="up">
      <slot />
    </div>
  </div>
</div>
