---
interface Props {
  status: 'stable' | 'beta' | 'deprecated';
}

const { status } = Astro.props;

const config = {
  stable: { label: 'Stable', class: 'bg-green-500/10 text-green-400 border-green-500/20' },
  beta: { label: 'Beta', class: 'bg-amber-500/10 text-amber-400 border-amber-500/20' },
  deprecated: { label: 'Deprecated', class: 'bg-red-500/10 text-red-400 border-red-500/20' },
};
const c = config[status];
---

<span class={`inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium border ${c.class}`}>
  {status === 'beta' && (
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
    </svg>
  )}
  {status === 'stable' && (
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
    </svg>
  )}
  {status === 'deprecated' && (
    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  )}
  {c.label}
</span>
