---
interface Props {
  title: string;
  description?: string;
  class?: string;
}

const { title, description, class: className = '' } = Astro.props;
---

<section class={`py-12 ${className}`}>
  <div class="mb-8" data-reveal="up">
    <h2 class="text-3xl font-bold tracking-tight">{title}</h2>
    {description && (
      <p class="mt-3 text-lg text-[rgb(var(--color-text-secondary))]">{description}</p>
    )}
  </div>
  <div>
    <slot />
  </div>
</section>
