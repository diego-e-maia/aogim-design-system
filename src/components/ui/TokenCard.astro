---
interface Props {
  name: string;
  value: string;
  type: 'color' | 'space' | 'font' | 'radius' | 'text';
}
const { name, value, type } = Astro.props;

const previewMap: Record<string, string> = {
  '--color-primary': '#d68020',
  '--color-secondary': '#8b55ff',
};
---

<div class="p-4 rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card-bg))]">
  <div class="flex items-center gap-3 mb-3">
    {type === 'color' && (
      <div class="w-10 h-10 rounded-lg border border-[rgb(var(--color-border))] shrink-0" style={`background: ${previewMap[name] || value}`}></div>
    )}
    {type === 'space' && (
      <div class="w-10 h-6 rounded bg-brand-500/20 shrink-0 flex items-center justify-center">
        <div class="w-full h-1 rounded bg-brand-500" style={`max-width: ${value}`}></div>
      </div>
    )}
    {type === 'font' && (
      <div class="w-10 h-10 rounded-lg bg-dark-100 dark:bg-dark-800 shrink-0 flex items-center justify-center">
        <span class="text-lg font-bold">Aa</span>
      </div>
    )}
    {(type === 'radius' || type === 'text') && (
      <div class="w-10 h-10 rounded-lg bg-dark-100 dark:bg-dark-800 shrink-0 flex items-center justify-center">
        <span class="text-xs font-mono">{value}</span>
      </div>
    )}
  </div>
  <div class="font-mono text-sm font-medium">{name}</div>
  <div class="text-xs text-[rgb(var(--color-text-secondary))] mt-1">{value}</div>
</div>
