---
interface AccordionItem {
  title: string;
  content: string;
}

interface Props {
  items: AccordionItem[];
  allowMultiple?: boolean;
  class?: string;
}

const { items, allowMultiple = false, class: className = '' } = Astro.props;
const accordionId = 'accordion-' + Math.random().toString(36).slice(2, 8);
---

<div
  id={accordionId}
  data-accordion={allowMultiple ? 'multiple' : 'single'}
  class={`divide-y divide-[rgb(var(--color-border))] rounded-xl border border-[rgb(var(--color-border))] overflow-hidden ${className}`}
>
  {items.map((item, i) => (
    <div data-accordion-item>
      <button
        data-accordion-header
        type="button"
        class="flex items-center justify-between w-full px-5 py-4 text-left font-medium hover:bg-dark-100 dark:hover:bg-dark-800 transition-colors"
        aria-expanded="false"
      >
        <span>{item.title}</span>
        <svg class="w-5 h-5 text-[rgb(var(--color-text-secondary))] transition-transform duration-200 accordion-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div data-accordion-body class="accordion-body">
        <div class="px-5 pb-4 text-sm text-[rgb(var(--color-text-secondary))] leading-relaxed">
          {item.content}
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll('[data-accordion]').forEach((accordion) => {
    const allowMultiple = accordion.getAttribute('data-accordion') === 'multiple';

    accordion.querySelectorAll('[data-accordion-header]').forEach((header) => {
      header.addEventListener('click', () => {
        const item = header.closest('[data-accordion-item]');
        const body = item.querySelector('[data-accordion-body]');
        const isOpen = header.getAttribute('aria-expanded') === 'true';

        if (!allowMultiple) {
          accordion.querySelectorAll('[data-accordion-item]').forEach((other) => {
            const otherHeader = other.querySelector('[data-accordion-header]');
            const otherBody = other.querySelector('[data-accordion-body]');
            if (other !== item && otherHeader.getAttribute('aria-expanded') === 'true') {
              otherHeader.setAttribute('aria-expanded', 'false');
              otherBody.style.gridTemplateRows = '0fr';
            }
          });
        }

        header.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        body.style.gridTemplateRows = isOpen ? '0fr' : '1fr';
      });
    });
  });
</script>

<style>
  .accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .accordion-body > div {
    overflow: hidden;
  }
</style>
