---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<nav id="toc" class={`hidden xl:block w-56 flex-shrink-0 ${className}`} aria-label="Tabela de Conteúdo">
  <div class="sticky top-24">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-secondary))] mb-3">
      Nesta página
    </h4>
    <ul id="toc-list" class="space-y-1 text-sm border-l border-[rgb(var(--color-border))]">
      <li class="text-[rgb(var(--color-text-secondary))] pl-3">Carregando...</li>
    </ul>
  </div>
</nav>

<script>
  (() => {
    const article = document.querySelector('article');
    const tocList = document.getElementById('toc-list');
    const tocNav = document.getElementById('toc');

    if (!article || !tocList) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      tocNav?.classList.add('hidden');
      return;
    }

    const items = [];
    headings.forEach((h, i) => {
      if (!h.id) {
        h.id = 'heading-' + i;
      }
      items.push({
        id: h.id,
        text: h.textContent.trim(),
        tag: h.tagName,
      });
    });

    const visible = new Set();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            visible.add(entry.target.id);
          } else {
            visible.delete(entry.target.id);
          }
        });
        updateActive();
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));

    function updateActive() {
      const links = tocList.querySelectorAll('a');
      let activeId = null;
      headings.forEach((h) => {
        if (visible.has(h.id)) activeId = h.id;
      });
      links.forEach((link) => {
        const isActive = link.getAttribute('href') === '#' + activeId;
        link.classList.toggle('text-brand-500', isActive);
        link.classList.toggle('font-medium', isActive);
        link.classList.toggle('border-brand-500', isActive);
        link.classList.toggle('text-[rgb(var(--color-text-secondary))]', !isActive);
        link.classList.toggle('border-transparent', !isActive);
      });
    }

    tocList.innerHTML = items
      .map((item) => {
        const padding = item.tag === 'H3' ? 'pl-7' : 'pl-3';
        return `<li class="${padding} border-l border-inherit">
          <a href="#${item.id}"
             class="block py-1 text-[rgb(var(--color-text-secondary))] border-l border-transparent -ml-px transition-colors hover:text-[rgb(var(--color-text))]">
            ${item.text}
          </a>
        </li>`;
      })
      .join('');

    tocList.addEventListener('click', (e) => {
      const link = e.target.closest('a');
      if (link) {
        e.preventDefault();
        const id = link.getAttribute('href')?.slice(1);
        if (id) {
          const el = document.getElementById(id);
          if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      }
    });
  })();
</script>
