---
import SidebarContent from './SidebarContent.astro';

interface Props {
  locale?: string;
}

const { locale = 'pt' } = Astro.props;
---

<div data-mobile-menu class="fixed inset-0 z-40 hidden">
  <div data-menu-backdrop class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute left-0 top-16 bottom-0 w-[280px] bg-[rgb(var(--color-sidebar-bg))] border-r border-[rgb(var(--color-border))] overflow-y-auto shadow-2xl">
    <SidebarContent locale={locale} />
  </div>
</div>

<script>
  const menu = document.querySelector('[data-mobile-menu]');
  const backdrop = document.querySelector('[data-menu-backdrop]');
  const toggle = document.querySelector('[data-toggle-menu]');
  if (menu && toggle) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      document.body.classList.toggle('overflow-hidden');
    });
    backdrop?.addEventListener('click', () => {
      menu.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    });
  }
</script>
