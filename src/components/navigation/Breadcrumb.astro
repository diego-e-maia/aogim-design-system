---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center gap-2 text-sm">
    <li>
      <a href="/" class="text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text))] transition-colors">
        Home
      </a>
    </li>
    {items.map((item) => (
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-[rgb(var(--color-text-secondary))]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a
          href={item.href}
          class="text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text))] transition-colors"
        >
          {item.label}
        </a>
      </li>
    ))}
  </ol>
</nav>
