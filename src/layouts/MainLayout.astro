---
import { ViewTransitions } from 'astro:transitions';
import SEO from '../components/ui/SEO.astro';
import Header from '../components/layout/Header.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  locale?: string;
}

const {
  title = 'AOGIM Design System',
  description = 'Uma Igreja. Uma Família. Um Lugar de Transformação.',
  image,
  canonical,
  locale = 'pt',
} = Astro.props;

const pageTitle = title.includes('AOGIM Design System')
  ? title
  : `${title} | AOGIM Design System`;
---

<!doctype html>
<html lang={locale} data-theme="aogim">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function() {
        var theme;
        try {
          theme = localStorage.getItem('theme');
        } catch (e) {}
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.classList.add(theme);
        localStorage.setItem('theme', theme);
      })();
    </script>
    <ViewTransitions />
    <title>{pageTitle}</title>
    <SEO title={title} description={description} image={image} canonical={canonical} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header locale={locale} />
    <div class="flex flex-1">
      <Sidebar locale={locale} />
      <main class="flex-1 min-h-[calc(100vh-64px)]">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
          <slot />
        </div>
      </main>
    </div>
    <Footer locale={locale} />
    <script>
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('[data-reveal]').forEach((el) => {
          if (!el.classList.contains('revealed')) {
            const dir = el.getAttribute('data-reveal') || 'up';
            el.classList.add(`reveal-${dir}`);
            const obs = new IntersectionObserver(
              (entries) => {
                for (const entry of entries) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    obs.unobserve(entry.target);
                  }
                }
              },
              { rootMargin: '0px 0px -60px 0px', threshold: 0.1 }
            );
            obs.observe(el);
          }
        });
      });
    </script>
  </body>
</html>
